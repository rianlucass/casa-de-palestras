<header id="header" class="fixed top-0 left-0 right-0 z-50">

  <!-- Topbar: some ao rolar -->
  <div id="topbar" class="bg-primary-dark transition-all duration-300 overflow-hidden" style="max-height: 40px;">
    <div class="max-w-7xl mx-auto px-6 h-8 flex items-center justify-between">
      <p class="font-body text-xs text-white/60 hidden md:block tracking-wide">
        Conectando ideias a pessoas em todo o mundo
      </p>
      <div class="flex items-center gap-5 ml-auto">
        <a href="https://www.instagram.com/casadeconteudo_oficial/" class="font-body text-xs text-white/60 hover:text-primary transition-colors tracking-wide">Instagram</a>
        <span class="text-white/20">|</span>
        <a href="https://www.linkedin.com/company/casa-de-palestras---palestras-e-eventos/" class="font-body text-xs text-white/60 hover:text-primary transition-colors tracking-wide">LinkedIn</a>
        <span class="text-white/20">|</span>
        <a href="#" class="font-body text-xs text-white/60 hover:text-primary transition-colors tracking-wide">WhatsApp</a>
      </div>
    </div>
  </div>

  <!-- Nav principal: fundo branco -->
  <div id="main-nav" class="bg-white border-b border-gray-100 transition-all duration-300">
    <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <img src="/img/logo/2-logos.png" alt="Casa de Palestras" class="h-10 md:h-16 w-auto"
             onerror="this.style.display='none'; this.nextElementSibling.style.display='block'">
        <span style="display:none" class="font-title text-2xl font-bold text-primary-dark tracking-wide">
          Casa de <span class="text-primary">Palestras</span>
        </span>
      </a>

      <!-- Nav Desktop -->
      <nav class="hidden lg:flex items-center gap-1">
        <a href="/" class="nav-link font-body text-sm font-medium text-text-primary hover:text-primary px-4 py-2 relative
           after:absolute after:bottom-0 after:left-4 after:right-4 after:h-0.5 after:bg-primary
           after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300
           tracking-wide transition-colors">Home</a>
        <a href="/curadoria" class="nav-link font-body text-sm font-medium text-text-primary hover:text-primary px-4 py-2 relative
           after:absolute after:bottom-0 after:left-4 after:right-4 after:h-0.5 after:bg-primary
           after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300
           tracking-wide transition-colors">Curadoria</a>
        <a href="/estrategias" class="nav-link font-body text-sm font-medium text-text-primary hover:text-primary px-4 py-2 relative
           after:absolute after:bottom-0 after:left-4 after:right-4 after:h-0.5 after:bg-primary
           after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300
           tracking-wide transition-colors">Estratégias Digitais</a>
        <a href="/mentoria" class="nav-link font-body text-sm font-medium text-text-primary hover:text-primary px-4 py-2 relative
           after:absolute after:bottom-0 after:left-4 after:right-4 after:h-0.5 after:bg-primary
           after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300
           tracking-wide transition-colors">Mentoria</a>
        <a href="/sobre" class="nav-link font-body text-sm font-medium text-text-primary hover:text-primary px-4 py-2 relative
           after:absolute after:bottom-0 after:left-4 after:right-4 after:h-0.5 after:bg-primary
           after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300
           tracking-wide transition-colors">Sobre Nós</a>
        <a href="/contato"
           class="ml-4 bg-secondary hover:bg-secondary-dark text-white font-body font-semibold text-sm
                  px-6 py-2.5 rounded transition-colors tracking-wide uppercase">
          Fale conosco
        </a>
      </nav>

      <!-- Hamburger Mobile -->
      <button id="menu-btn" class="lg:hidden flex flex-col gap-1.5 p-2" aria-label="Abrir menu">
        <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-text-primary transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Menu Mobile -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-b border-gray-100 shadow-lg">
    <nav class="flex flex-col px-6 py-4 gap-1">
      <a href="/" class="font-body text-sm font-medium text-text-primary hover:text-primary hover:bg-gray-50 transition-colors tracking-wide px-3 py-3 rounded border-b border-gray-100">Home</a>
      <a href="/curadoria" class="font-body text-sm font-medium text-text-primary hover:text-primary hover:bg-gray-50 transition-colors tracking-wide px-3 py-3 rounded border-b border-gray-100">Curadoria</a>
      <a href="/estrategias" class="font-body text-sm font-medium text-text-primary hover:text-primary hover:bg-gray-50 transition-colors tracking-wide px-3 py-3 rounded border-b border-gray-100">Estratégias Digitais</a>
      <a href="/mentoria" class="font-body text-sm font-medium text-text-primary hover:text-primary hover:bg-gray-50 transition-colors tracking-wide px-3 py-3 rounded border-b border-gray-100">Mentoria</a>
      <a href="/sobre" class="font-body text-sm font-medium text-text-primary hover:text-primary hover:bg-gray-50 transition-colors tracking-wide px-3 py-3 rounded border-b border-gray-100">Sobre Nós</a>
      <a href="/contato"
         class="mt-3 bg-secondary hover:bg-orange-500 text-white font-body font-semibold text-sm
                px-6 py-3 rounded text-center transition-colors tracking-wide uppercase">
        Fale conosco
      </a>
    </nav>
  </div>

</header>
