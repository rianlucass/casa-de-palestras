<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('mentoria-form');
    const submitButton = document.getElementById('cta-submit-mentoria');
    const feedback = document.getElementById('mentoria-feedback');

    if (form && submitButton && feedback) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const nome = document.getElementById('nome')?.value.trim();
        const email = document.getElementById('email')?.value.trim();
        const telefone = document.getElementById('telefone')?.value.trim();
        const mensagem = document.getElementById('mensagem')?.value.trim();

        if (!nome || !email || !telefone || !mensagem) {
          feedback.textContent = 'Preencha os campos obrigatórios.';
          feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-red-50 text-red-600';
          feedback.classList.remove('hidden');
          return;
        }

        submitButton.disabled = true;
        submitButton.textContent = 'Enviando...';

        try {
          const response = await fetch('/api/mentoria', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ nome, email, telefone, mensagem }),
          });

          if (response.ok) {
            feedback.textContent = 'Aplicação enviada! Nossa equipe entrará em contato em breve.';
            feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-green-50 text-green-700';
            form.reset();
          } else {
            throw new Error('Erro ao enviar formulário');
          }
        } catch (error) {
          feedback.textContent = 'Erro ao enviar. Tente novamente mais tarde.';
          feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-red-50 text-red-600';
        } finally {
          feedback.classList.remove('hidden');
          submitButton.disabled = false;
          submitButton.textContent = 'Quero entrar na mentoria';
        }
      });
    }

    if (typeof gsap !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);

      // Animação: O Método
      gsap.from(".metodo-title", {
