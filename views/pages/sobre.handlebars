    }

    /* Badge de seção — estilo pílula */
    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        border: 1px solid rgba(228, 6, 184, 0.4);
        border-radius: 50px;
        padding: 6px 18px;
        backdrop-filter: blur(8px);
        background: rgba(228, 6, 184, 0.08);
    }

    /* Texto da badge */
    .section-badge span {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        font-family: 'Montserrat', sans-serif;
        color: #E406B8;
    }

    /* Ponto pulsante */
    .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #E406B8;
        animation: pulseDot 2s ease-in-out infinite;
    }

    @keyframes pulseDot {

        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.5;
            transform: scale(0.7);
        }
    }

    /* "Essência" — título palavra destaque em gradiente */
    .title-gradient {
        background: linear-gradient(110deg, #38b6ff 0%, #E406B8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-family: 'DM Serif Display', 'Playfair Display', serif;
        font-style: italic;
        font-weight: 400;
    }

    /* Cards de estatísticas */
    .stat-card {
        backdrop-filter: blur(12px);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 16px;
        padding: 18px 28px;
        text-align: center;
        transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    }

    .stat-card:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(228, 6, 184, 0.4);
        transform: translateY(-3px);
    }

    .stat-number {
        font-family: 'Oswald', sans-serif;
        font-weight: 700;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
        background: linear-gradient(110deg, #38b6ff, #E406B8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stat-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
        margin-top: 4px;
    }

    /* Linhas diagonais decorativas */
    .diagonal-lines {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .diagonal-lines::before,
    .diagonal-lines::after {
        content: '';
        position: absolute;
        width: 1px;
        top: 0;
        bottom: 0;
        background: linear-gradient(to bottom, transparent 0%, rgba(255, 255, 255, 0.06) 30%, rgba(255, 255, 255, 0.06) 70%, transparent 100%);
    }

    .diagonal-lines::before {
        left: 20%;
    }

    .diagonal-lines::after {
        right: 20%;
    }

    /* Scroll indicator vertical line */
    @keyframes scrollPulse {
        0% {
            transform: translateY(-100%);
            opacity: 0;
        }

        40% {
            opacity: 1;
        }

        100% {
            transform: translateY(100%);
            opacity: 0;
        }
    }

    .scroll-line-fill {
        animation: scrollPulse 2.2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }

    /* Grain noise overlay */
    .grain-overlay {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        opacity: 0.045;
    }

    /* Ken Burns suave no bg */
    @keyframes kenBurns {
        0% {
            transform: scale(1.08);
        }

        100% {
            transform: scale(1);
        }
    }

    .hero-bg-img {
        animation: kenBurns 8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>


