<script>
    (function () {
        'use strict';

        const DELAYS = [0, 0.12, 0.24, 0.42, 0.58, 0.70, 0.82, 0.94];

        function animateHero() {
            // Palavras do título (hero-word)
            const words = document.querySelectorAll('.hero-word');
            words.forEach(function (el, i) {
                setTimeout(function () {
                    el.classList.add('visible');
                }, 200 + i * 130);
            });

            // Linha decorativa (hero-line)
            setTimeout(function () {
                const line = document.querySelector('.hero-line');
                if (line) line.style.width = '120px';
            }, 600);

            // Elementos fade (hero-fade) com stagger
            const fades = document.querySelectorAll('.hero-fade');
            fades.forEach(function (el, i) {
                setTimeout(function () {
                    el.classList.add('visible');
                }, 550 + i * 150);
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', animateHero);
        } else {
            animateHero();
        }
    }());
</script>


