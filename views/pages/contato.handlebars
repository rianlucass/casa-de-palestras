        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

            <!-- ── Coluna esquerda: Texto ── -->
            <div class="cf-fade">

                <!-- Badge -->
                <div class="flex items-center gap-3 mb-7">
                    <span class="block w-8 h-px" style="background: linear-gradient(to right, transparent, rgba(228,6,184,0.7));"></span>
                    <span class="font-body text-[10px] font-bold tracking-[0.35em] uppercase text-secondary">Fale com a Gente</span>
                </div>

                <!-- Título -->
                <h1 class="font-title font-bold text-white uppercase tracking-tighter leading-[0.9] mb-7"
                    style="font-size: clamp(2.4rem, 5.5vw, 5rem);">
                    Estamos Prontos para<br>
                    <span style="font-family: 'DM Serif Display','Playfair Display',serif; font-style: italic; font-weight: 400; background: linear-gradient(110deg, #38b6ff, #E406B8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Transformar</span><br>
                    seu Projeto
                </h1>

                <!-- Subtítulo -->
                <p class="font-body text-white/60 text-base md:text-lg leading-relaxed mb-4 max-w-md">
                    Converse conosco e descubra como podemos levar sua marca a outro patamar.
                </p>
                <p class="font-body text-white/40 text-sm md:text-base leading-relaxed mb-12 max-w-md">
                    Preencha o formulário ou entre em contato diretamente pelos nossos canais.
                </p>

                <!-- Canais diretos -->
                <div class="flex flex-col gap-4">

                    <!-- WhatsApp -->
                    <a href="https://wa.me/5511999999999" target="_blank" rel="noopener noreferrer"
                       class="group flex items-center gap-4 transition-all duration-300">
                        <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 border border-white/10 group-hover:border-[#25D366]/40 transition-colors duration-300"
                             style="background: rgba(37,211,102,0.08);">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24">
                                <path fill="#25D366" d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                                <path fill="#25D366" d="M12 0C5.373 0 0 5.373 0 12c0 2.125.554 4.122 1.524 5.855L.057 23.881l6.199-1.443A11.942 11.942 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.007-1.374l-.36-.214-3.68.856.874-3.598-.234-.369A9.818 9.818 0 1112 21.818z"/>
                            </svg>
                        </div>
                        <div>
