                            <p class="font-body text-white/70 text-sm group-hover:text-white transition-colors duration-300">+55 (11) 9 9999-9999</p>
                        </div>
                    </a>

                    <!-- E-mail -->
                    <a href="mailto:contato@casadepalestras.com.br"
