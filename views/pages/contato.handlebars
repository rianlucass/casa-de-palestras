                        <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 border border-white/10 group-hover:border-primary/40 transition-colors duration-300"
                             style="background: rgba(56,182,255,0.08);">
                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-body text-[10px] font-bold tracking-[0.2em] uppercase text-white/30 mb-0.5">E-mail</p>
                            <p class="font-body text-white/70 text-sm group-hover:text-white transition-colors duration-300">contato@casadepalestras.com.br</p>
                        </div>
                    </a>

                    <!-- Instagram -->
                    <a href="https://www.instagram.com/casadeconteudo_oficial/" target="_blank" rel="noopener noreferrer"
                       class="group flex items-center gap-4 transition-all duration-300">
                        <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0 border border-white/10 group-hover:border-secondary/40 transition-colors duration-300"
                             style="background: rgba(228,6,184,0.08);">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24">
                                <defs>
                                    <linearGradient id="ig-grad" x1="0%" y1="100%" x2="100%" y2="0%">
                                        <stop offset="0%" stop-color="#f09433"/>
                                        <stop offset="25%" stop-color="#e6683c"/>
                                        <stop offset="50%" stop-color="#dc2743"/>
                                        <stop offset="75%" stop-color="#cc2366"/>
                                        <stop offset="100%" stop-color="#bc1888"/>
                                    </linearGradient>
                                </defs>
                                <rect x="2" y="2" width="20" height="20" rx="6" ry="6" fill="none" stroke="url(#ig-grad)" stroke-width="1.8"/>
                                <circle cx="12" cy="12" r="4" fill="none" stroke="url(#ig-grad)" stroke-width="1.8"/>
                                <circle cx="17.5" cy="6.5" r="1" fill="url(#ig-grad)"/>
                            </svg>
                        </div>
                        <div>
                            <p class="font-body text-[10px] font-bold tracking-[0.2em] uppercase text-white/30 mb-0.5">Instagram</p>
                            <p class="font-body text-white/70 text-sm group-hover:text-white transition-colors duration-300">@casadepalestras</p>
                        </div>
                    </a>
                </div>
            </div>

            <!-- ── Coluna direita: Formulário ── -->
            <div class="cf-fade" style="transition-delay: 150ms;">
                <div class="bg-white rounded-[2rem] border border-gray-100 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.5)] p-8 md:p-12 relative overflow-hidden">

                    <!-- Decor canto -->
                    <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-primary/10 to-transparent rounded-bl-full pointer-events-none"></div>

                    <h2 class="font-title font-extrabold text-text-primary leading-tight mb-2 relative z-10"
                        style="font-size: clamp(1.6rem, 2.5vw, 2rem);">
                        Envie uma <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-dark">Mensagem</span>
                    </h2>
                    <p class="font-body text-text-muted text-sm leading-relaxed mb-10 relative z-10">
                        Responderemos assim que possível. Estamos ansiosos para ouvir sobre seu projeto e explorar como podemos colaborar!
                    </p>

                    <form id="contact-form" novalidate class="space-y-8 relative z-10">

                        <!-- Nome -->
                        <div>
                            <label class="block font-body text-xs font-bold uppercase tracking-wider text-gray-400 mb-1" for="cf-nome">
                                Nome completo <span class="text-secondary">*</span>
                            </label>
                            <input id="cf-nome" name="nome" type="text"
                                   placeholder="Seu nome"
                                   class="input-flushed-ct"
                                   autocomplete="name" required>
                        </div>

                        <!-- E-mail -->
                        <div>
                            <label class="block font-body text-xs font-bold uppercase tracking-wider text-gray-400 mb-1" for="cf-email">
                                E-mail <span class="text-secondary">*</span>
                            </label>
                            <input id="cf-email" name="email" type="email"
                                   placeholder="seu@email.com"
                                   class="input-flushed-ct"
                                   autocomplete="email" required>
                        </div>

                        <!-- Telefone -->
                        <div>
                            <label class="block font-body text-xs font-bold uppercase tracking-wider text-gray-400 mb-1" for="cf-telefone">
                                Telefone / WhatsApp
                            </label>
                            <input id="cf-telefone" name="telefone" type="tel"
                                   placeholder="(11) 9 9999-9999"
                                   class="input-flushed-ct"
                                   autocomplete="tel">
                        </div>

                        <!-- Mensagem -->
                        <div>
                            <label class="block font-body text-xs font-bold uppercase tracking-wider text-gray-400 mb-1" for="cf-mensagem">
                                Como podemos ajudar?
                            </label>
                            <textarea id="cf-mensagem" name="mensagem"
                                      placeholder="Conte um pouco sobre seu projeto ou evento..."
                                      rows="3"
                                      class="input-flushed-ct resize-none"></textarea>
                        </div>

                        <p id="contact-feedback" class="hidden text-sm font-body text-center py-2 rounded-lg"></p>

                        <!-- Submit -->
                        <button type="submit" id="cf-submit" class="btn-submit">
                            <span id="cf-btn-text">Enviar Mensagem</span>
                            <svg id="cf-spinner" class="hidden w-5 h-5 mx-auto animate-spin" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
                            </svg>
                        </button>

                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Linha inferior -->
    <div class="absolute bottom-0 left-0 right-0 h-[1px]"
         style="background: linear-gradient(90deg, transparent 0%, rgba(56,182,255,0.3) 40%, rgba(228,6,184,0.3) 60%, transparent 100%);"></div>
</section>

<script>
(function () {
    'use strict';

    /* ── Scroll reveal ── */
    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add('is-visible'); observer.unobserve(e.target); }
        });
    }, { threshold: 0.15 });
    document.querySelectorAll('.cf-fade').forEach(function (el) { observer.observe(el); });

    /* ── Máscara de telefone simples ── */
    var telInput = document.getElementById('cf-telefone');
    if (telInput) {
        telInput.addEventListener('input', function () {
            var v = this.value.replace(/\D/g, '').slice(0, 11);
            if (v.length >= 7) {
                this.value = '(' + v.slice(0, 2) + ') ' + v.slice(2, 7) + (v.length > 7 ? '-' + v.slice(7) : '');
            } else if (v.length >= 3) {
                this.value = '(' + v.slice(0, 2) + ') ' + v.slice(2);
            } else if (v.length >= 1) {
                this.value = '(' + v;
            }
        });
    }

    /* ── Envio do formulário ── */
    var form     = document.getElementById('contact-form');
    var btn      = document.getElementById('cf-submit');
    var btnText  = document.getElementById('cf-btn-text');
    var spinner  = document.getElementById('cf-spinner');
    var feedback = document.getElementById('contact-feedback');

    form.addEventListener('submit', async function (e) {
        e.preventDefault();

        var nome     = document.getElementById('cf-nome').value.trim();
        var email    = document.getElementById('cf-email').value.trim();
        var telefone = document.getElementById('cf-telefone').value.trim();
        var mensagem = document.getElementById('cf-mensagem').value.trim();

        if (!nome || !email) {
            feedback.textContent = 'Por favor, preencha nome e e-mail.';
            feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-red-50 text-red-600';
            feedback.classList.remove('hidden');
            return;
        }

        btn.disabled = true;
        btnText.classList.add('hidden');
        spinner.classList.remove('hidden');
        feedback.classList.add('hidden');

        try {
            var response = await fetch('/contato', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nome: nome, email: email, telefone: telefone, mensagem: mensagem || '—' })
            });

            if (response.ok) {
                feedback.textContent = 'Mensagem enviada! Entraremos em contato em breve.';
                feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-green-50 text-green-700';
                form.reset();
            } else {
                feedback.textContent = 'Não foi possível enviar. Tente novamente.';
                feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-red-50 text-red-600';
            }
        } catch (err) {
            feedback.textContent = 'Erro de conexão. Verifique sua internet.';
            feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-red-50 text-red-600';
        } finally {
            feedback.classList.remove('hidden');
            btn.disabled = false;
            btnText.classList.remove('hidden');
            spinner.classList.add('hidden');
        }
    });
}());
</script>
