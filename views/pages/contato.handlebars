<!-- ══════════════════════════════════════════════════════════
     CONTATO — Formulário de Contato
     Rota: GET /contato
══════════════════════════════════════════════════════════ -->

<style>
    /* ── Inputs — mesmo padrão curadoria/estratégias ── */
    .input-flushed-ct {
        width: 100%;
        background: transparent;
        border: none;
        border-bottom: 2px solid #E5E7EB;
        padding: 12px 0;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.95rem;
        color: #111827;
        transition: all 0.3s ease;
    }
    .input-flushed-ct:focus {
        outline: none;
        box-shadow: none;
        border-bottom-color: #38b6ff;
    }
    .input-flushed-ct::placeholder { color: #9CA3AF; }

    /* ── Ken Burns no banner ── */
    @keyframes kenBurnsContact {
        0%   { transform: scale(1)    translate(0, 0); }
        50%  { transform: scale(1.06) translate(-1.5%, 1%); }
        100% { transform: scale(1)    translate(0, 0); }
    }
    .contact-bg-img { animation: kenBurnsContact 18s ease-in-out infinite; }

    /* ── Fade-in ── */
    .cf-fade { opacity: 0; transform: translateY(22px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .cf-fade.is-visible { opacity: 1; transform: translateY(0); }

    /* ── Botão submit ── */
    .btn-submit {
        width: 100%;
        background: #38b6ff;
        border: none;
        border-radius: 0.75rem;
        padding: 1rem;
        color: #fff;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8125rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        cursor: pointer;
        transition: box-shadow 0.3s, transform 0.3s;
    }
    .btn-submit:hover { box-shadow: 0 8px 24px -4px rgba(56,182,255,0.5); transform: translateY(-2px); }
    .btn-submit:active { transform: translateY(0); }
    .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }

</style>

<!-- ══════════════════════════════════
     HERO / FORM SECTION
══════════════════════════════════ -->
<section class="relative min-h-screen flex items-center overflow-hidden">

    <!-- Banner de fundo -->
    <div class="absolute inset-0 overflow-hidden">
        <img src="/img/banners/15.png"
             alt=""
             class="contact-bg-img absolute inset-0 w-full h-full object-cover object-center"
             style="transform-origin: center center;">
    </div>

    <!-- Overlay 1 — escurecimento geral forte -->
    <div class="absolute inset-0" style="background: rgba(8,8,16,0.82);"></div>

    <!-- Overlay 2 — gradiente diagonal -->
    <div class="absolute inset-0"
         style="background: linear-gradient(125deg, rgba(10,8,28,0.92) 0%, rgba(8,10,22,0.70) 55%, rgba(6,6,14,0.88) 100%);"></div>

    <!-- Overlay 3 — halo azul esquerda -->
    <div class="absolute inset-0 pointer-events-none"
         style="background: radial-gradient(ellipse at 15% 60%, rgba(24,119,242,0.14) 0%, transparent 55%);"></div>

    <!-- Overlay 4 — halo rosa direita -->
    <div class="absolute inset-0 pointer-events-none"
         style="background: radial-gradient(ellipse at 85% 40%, rgba(228,6,184,0.10) 0%, transparent 55%);"></div>

    <!-- Grain -->
