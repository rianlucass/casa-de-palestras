<!-- GSAP + ScrollTrigger via CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger);

        /* ── Hero: fade-in dos elementos (Seção 1) ── */
        gsap.to(".hero-element", {
            opacity: 1,
            y: 0,
            duration: 1,
            stagger: 0.2,
            ease: "power3.out",
            delay: 0.2
        });

        /* ── Consultoria (Seção 2): Premium Hero ── */

        // 1. Animação de Entrada Inicial (Fade Up + Textos)
        const consultEntry = gsap.timeline({
            scrollTrigger: {
                trigger: "#consult-section",
                start: "top 75%", // Inicia quando 25% da seção está visível na tela
                once: true
            }
        });

        // Fade-up dos textos centrais (exclui o botão — animado separadamente)
        consultEntry.from(".consult-content > *:not(#consult-cta)", {
            opacity: 0,
            y: 50,
            duration: 1.4,
            stagger: 0.2,
            ease: "power4.out"
        });

        // Botão CTA animado separadamente — garantia de sempre aparecer
        consultEntry.to("#consult-cta", {
            opacity: 1,
            y: 0,
            duration: 0.9,
            ease: "power3.out"
        }, "-=0.6");

        // Fade in das imagens para começar no centro inicialmente
        consultEntry.from(".imagem-flutuante", {
            opacity: 0,
            scale: 0.4,
            duration: 1.6,
            stagger: 0.15,
            ease: "back.out(1.2)",
        }, "-=1.0");

        // Badges de resultado — entram com bounce
        consultEntry.from(".stat-badge", {
            opacity: 0,
            scale: 0.75,
            y: 18,
            duration: 0.9,
            stagger: 0.2,
            ease: "back.out(1.8)"
        }, "-=0.8");

        // Flutuação suave dos badges (loop)
        gsap.utils.toArray(".stat-badge").forEach((badge, i) => {
            gsap.to(badge, {
                y: "+=10",
                duration: 2.2 + i * 0.4,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
                delay: i * 0.5
            });
        });

        // 2. Animação Scroll-linked via Vanilla JS (dispersão)
        const section = document.querySelector('.scroll-section');
        const images = document.querySelectorAll('.imagem-flutuante');

        window.addEventListener('scroll', () => {
            // Pega as dimensões e a posição atual da seção em relação à janela
            const rect = section.getBoundingClientRect();

            // Calcula o progresso do scroll de 0 (início) até 1 (fim da seção)
            let scrollProgress = 0;

            if (rect.top <= 0) {
                // Subtraímos a altura da janela (innerHeight) para que o progresso
                // chegue a 1 exatamente quando o final da seção bater no final da tela
                const scrollableDistance = rect.height - window.innerHeight;
                scrollProgress = Math.abs(rect.top) / scrollableDistance;
            }

            // Trava o progresso entre 0 e 1
            scrollProgress = Math.max(0, Math.min(1, scrollProgress));

            // Define um fator de escala para o espalhamento focar em telas menores (Responsividade)
            let scaleFactor = 1;
            if (window.innerWidth < 768) {
                scaleFactor = 0.45; // Em celulares, espalha menos para não vazar a tela
            } else if (window.innerWidth < 1024) {
                scaleFactor = 0.75; // Em tablets, espalha mediano
            }

            // Aplica o cálculo individualmente para cada imagem
            images.forEach(img => {
                // Pega os valores configurados no HTML
                const tx = parseFloat(img.getAttribute('data-tx'));
                const ty = parseFloat(img.getAttribute('data-ty'));
                const rot = parseFloat(img.getAttribute('data-rot'));

                // Multiplica o valor final desejado pelo progresso e pelo espaçamento responsivo
                const currentX = (tx * scaleFactor) * scrollProgress;
                const currentY = (ty * scaleFactor) * scrollProgress;
                const currentRot = rot * scrollProgress;

                // Aplica as transformações CSS, mantendo o controle sobre as posições absolutas centrais
                img.style.transform = `translate(${currentX}px, ${currentY}px) rotate(${currentRot}deg)`;
            });
        });

        /* ── Serviços (Seção 3): Scroll Horizontal Tipográfico ── */
        const servicesSection = document.getElementById("services-section");
        const servicesWrapper = document.querySelector(".services-scroll-wrapper");
        
        if (servicesSection && servicesWrapper) {
            
            function getScrollAmount() {
                let wrapperWidth = servicesWrapper.scrollWidth;
                return -(wrapperWidth - window.innerWidth);
            }

            const tween = gsap.to(servicesWrapper, {
                x: getScrollAmount,
                ease: "none"
            });

            ScrollTrigger.create({
                trigger: servicesSection,
                start: "top top",
                end: () => `+=${servicesWrapper.scrollWidth - window.innerWidth}`,
                pin: true,
                animation: tween,
                scrub: 1,
                invalidateOnRefresh: true,
            });
        }

    });
</script>