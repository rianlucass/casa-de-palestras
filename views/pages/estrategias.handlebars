                padding: 12px 0;
                font-family: inherit;
                font-size: 0.95rem;
                color: #111827;
                transition: all 0.3s ease;
            }

            .input-flushed-est:focus {
                outline: none;
                box-shadow: none;
                border-bottom-color: #E406B8;
            }

            .input-flushed-est::placeholder {
                color: #9CA3AF;
            }
        </style>

        <script>
            function handleCtaFormSubmit(e) {
                e.preventDefault();
                const btn = document.getElementById('cta-submit-btn');
                const feedback = document.getElementById('cta-form-feedback');

                const nome = document.getElementById('cta-nome').value.trim();
                const email = document.getElementById('cta-email').value.trim();
                const mensagem = document.getElementById('cta-mensagem').value.trim();
                if (!nome || !email || !mensagem) return;

                btn.disabled = true;
                btn.textContent = 'Enviando...';
                btn.style.opacity = '0.7';

                /* Substituir o setTimeout por fetch('/contato', ...) quando o back-end estiver pronto */
                setTimeout(() => {
                    btn.textContent = 'Mensagem enviada ✓';
                    btn.style.backgroundColor = '#16a34a';
                    feedback.textContent = 'Em breve entraremos em contato!';
                    feedback.className = 'text-sm font-body text-center py-2 rounded-lg bg-green-50 text-green-700';
                    feedback.classList.remove('hidden');
                    document.getElementById('cta-form-estrategias').reset();
                }, 1200);
            }
        </script>
