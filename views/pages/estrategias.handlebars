<!-- ESTILOS DO EFEITO CROOKED -->
<style>
    /* Base das palavras interativas */
    .hover-word {
        position: relative;
        display: inline-block;
        cursor: pointer;
        text-decoration: underline;
        text-underline-offset: 8px;
        text-decoration-thickness: 2px;
        text-decoration-color: rgba(255, 255, 255, 0.3);
        z-index: 1;
        /* Mantém o texto acima do fundo */
        transition: all 0.3s ease;
        font-family: 'DM Serif Display', 'Playfair Display', serif;
        /* Fonte fora do padrão, mais criativa */
        font-style: italic;
        font-weight: 500;
    }

    /* O fundo que vai ficar "torto" */
    .hover-word::before {
        content: '';
        position: absolute;
        top: 4px;
        bottom: 0px;
        left: -12px;
        right: -12px;
        z-index: -1;
        opacity: 0;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        /* Animação com um leve 'bounce' */
        border-radius: 4px;
    }

    /* --- EFEITO 1: CASA DE PALESTRAS (AZUL) --- */
    .highlight-palestras::before {
        background-color: #1877F2;
        transform: rotate(-3deg) scale(0.9);
    }

    .highlight-palestras:hover {
        text-decoration-color: transparent;
        color: #fff;
    }

    .highlight-palestras:hover::before {
        opacity: 1;
        transform: rotate(-3deg) scale(1);
    }

    /* --- EFEITO 2: CASA DE CONTEÚDO (ROSA/LILÁS) --- */
    .highlight-conteudo::before {
        background-color: #E406B8;
        transform: rotate(3deg) scale(0.9);
    }

    .highlight-conteudo:hover {
        text-decoration-color: transparent;
        color: #fff;
    }

    .highlight-conteudo:hover::before {
        opacity: 1;
        transform: rotate(2deg) scale(1.2);
    }

    /* Ajuste sutil na logo tipo botão WORK do Homerun */
    .badge-hero {
        display: inline-block;
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 50px;
        padding: 8px 24px;
        font-size: 0.8rem;
        font-weight: bold;
        letter-spacing: 2px;
        color: #fff;
        margin-bottom: 30px;
        text-transform: uppercase;
    }
</style>

<!-- HERO: ESTRATEGIA DIGITAL -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#161616]">

    <!-- OVERLAY DE LOADING -->
    <div id="page-loader"
        class="fixed inset-0 z-[9999] bg-[#0f0f0f] flex flex-col items-center justify-center transition-opacity duration-700 ease-out">
        <div class="relative flex items-center justify-center w-24 h-24 mb-8">
            <div class="absolute inset-0 border-t-2 border-[#1877F2] rounded-full animate-spin"></div>
            <div class="absolute inset-2 border-r-2 border-[#E406B8] rounded-full animate-spin"
                style="animation-direction: reverse; animation-duration: 1.5s;"></div>
            <div class="absolute inset-4 border-b-2 border-white/50 rounded-full animate-spin"
                style="animation-duration: 5s;"></div>
        </div>
        <div class="text-white font-title text-sm md:text-base tracking-[0.3em] uppercase opacity-80 animate-pulse">
            Preparando estratégia...
        </div>
    </div>
    <!-- Script independente — não depende de GSAP nem de DOMContentLoaded -->
    <script>
        // Desabilita a restauração automática de scroll do browser para evitar
        // conflito com o GSAP ScrollTrigger que inicializa antes do scroll ser restaurado
        if ('scrollRestoration' in history) {
            history.scrollRestoration = 'manual';
        }
        window.scrollTo(0, 0);

        (function () {
            function removeLoader() {
                var loader = document.getElementById('page-loader');
                if (!loader) return;
                loader.style.opacity = '0';
                setTimeout(function () { if (loader.parentNode) loader.parentNode.removeChild(loader); }, 700);
            }
            // Fallback absoluto: remove após 3s no máximo
            var maxTimer = setTimeout(removeLoader, 3000);
            function onReady() {
                clearTimeout(maxTimer);
                setTimeout(removeLoader, 250);
            }
            if (document.readyState === 'complete') {
                onReady();
            } else {
                window.addEventListener('load', onReady, { once: true });
                // Se load demorar muito, DOMContentLoaded serve como safety net
                document.addEventListener('DOMContentLoaded', function () {
                    setTimeout(function () {
                        if (document.getElementById('page-loader')) removeLoader();
                    }, 2000);
                }, { once: true });
            }
        }());
    </script>

    <!-- Gradientes decorativos espalhados no fundo (escurecidos para matchar com bg dark) -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
