<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Registrar o ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    // --- ANIMAÇÃO DO HERO ---
    const tlHero = gsap.timeline({ defaults: { ease: "power3.out" } });

    tlHero.from(".hero-title", { y: 40, opacity: 0, duration: 1, delay: 0.2, clearProps: "all" })
      .from(".hero-subtitle", { y: 20, opacity: 0, duration: 0.8, clearProps: "all" }, "-=0.6")
      .from(".hero-cta", { scale: 0.9, opacity: 0, duration: 0.6, ease: "back.out(1.5)", clearProps: "all" }, "-=0.4");

    tlHero.from(".hero-card", {
      x: 50,
      opacity: 0,
      duration: 0.8,
      stagger: 0.15,
      clearProps: "all"
    }, "-=0.8");

    // --- ANIMAÇÃO SOBRE NÓS (Scroll) ---
    // Textos da Esquerda
    gsap.from(".sobre-item", {
      scrollTrigger: {
        trigger: "#sobre",
        start: "top 75%", // Inicia quando o topo da seção chega a 75% da altura da tela
      },
      y: 40,
      opacity: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: "power3.out"
    });

    // Grid Visual (Bento Box) da Direita
    gsap.from(".sobre-visual-item", {
      scrollTrigger: {
        trigger: "#sobre",
        start: "top 70%",
      },
      scale: 0.9,
      y: 30,
      opacity: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: "back.out(1.2)"
    });

    // Animação: O Método
    gsap.from(".metodo-title", {
      scrollTrigger: { trigger: "#metodo", start: "top 75%" },
      x: -50, opacity: 0, duration: 0.8, ease: "power3.out"
    });
    gsap.from(".method-item", {
      scrollTrigger: { trigger: "#metodo", start: "top 75%" },
      y: 40, opacity: 0, duration: 0.8, stagger: 0.2, ease: "power3.out"
    });

    // Animação: Vozes / Flex Accordion
    gsap.from(".vozes-title", {
      scrollTrigger: { trigger: "#vozes", start: "top 80%" },
      y: 30, opacity: 0, duration: 0.8, ease: "power3.out"
    });
    gsap.from(".vozes-container", {
      scrollTrigger: { trigger: "#vozes", start: "top 75%" },
      y: 50, opacity: 0, duration: 1, ease: "power3.out"
    });

    // Animação: CTA Master
    gsap.from(".cta-box", {
      scrollTrigger: { trigger: ".bg-primary", start: "top 80%" },
      scale: 0.95, y: 50, opacity: 0, duration: 0.8, ease: "back.out(1.5)"
    });

  });
</script>